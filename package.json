{
  "name": "@punkbit/react-hn-reader",
  "version": "1.1.0",
  "description": "An experimental React component for displaying Hacker News stories with beautiful parallax scrolling",
  "author": "Punkbit",
  "license": "MIT",
  "type": "module",
  "main": "./dist/react-hn-reader.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/react-hn-reader.es.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "build:preview": "tsc && vite build --mode preview",
    "build:all": "npm run build:preview && npm run build",
    "dev": "vite",
    "preview": "vite preview",
    "serve": "npx http-server ./dist/preview -p 8080 -o",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=16.8.0 || >=17.0.0 || >=18.0.0 || >=19.0.0",
    "react-dom": ">=16.8.0 || >=17.0.0 || >=18.0.0 || >=19.0.0",
    "styled-components": ">=5.0.0 || >=6.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react": "^4.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "styled-components": "^6.1.17",
    "typescript": "^5.3.0",
    "vite": "^6.0.0"
  },
  "keywords": [
    "react",
    "react-19",
    "hacker-news",
    "hn",
    "reader",
    "news",
    "component",
    "scrolling",
    "parallax",
    "typescript",
    "styled-components"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/punkbit/react-hn-reader.git"
  },
  "bugs": {
    "url": "https://github.com/punkbit/react-hn-reader/issues"
  },
  "homepage": "https://github.com/punkbit/react-hn-reader#readme"
}
